{
  "schemaVersion": 2,
  "modeId": "SkyrimGOG",
  "name": "Skyrim Special Edition GOG",
  "behaviorProfile": "gamebryo",
  "legacyFallback": false,
  "gameExecutables": [
    "SkyrimSE.exe",
    "SkyrimSELauncher.exe"
  ],
  "stopFolders": [
    "textures",
    "scripts",
    "meshes",
    "music",
    "shaders",
    "video",
    "interface",
    "facegen",
    "menus",
    "lodsettings",
    "lsdata",
    "sound",
    "strings",
    "seq",
    "grass",
    "tools",
    "CalienteTools",
    "SKSE",
    "Nemesis_Engine",
    "Pandora_Engine"
  ],
  "pluginExtensions": [
    ".esm",
    ".esl",
    ".esp"
  ],
  "orderedCriticalPluginNames": [
    "Skyrim.esm",
    "Update.esm",
    "Dawnguard.esm",
    "HearthFires.esm",
    "Dragonborn.esm"
  ],
  "supportedFormats": [
    "fomod"
  ],
  "discovery": {
    "stores": [
      {
        "store": "GOG",
        "id": "1711230643",
        "executableName": "SkyrimSE.exe",
        "registryKey": "HKEY_LOCAL_MACHINE\\SOFTWARE\\WOW6432Node\\GOG.com\\Games\\1711230643",
        "registryValueName": "PATH"
      }
    ]
  },
  "plugin": {
    "usesPlugins": true,
    "pluginDirectorySuffix": "Data",
    "supportsPluginAutoSorting": false,
    "maxAllowedActivePluginsCount": 255,
    "officialUnmanagedPluginListFiles": [
      "{GamePath}\\Skyrim.ccc"
    ],
    "policy": {
      "schemaVersion": 1,
      "addressSpaces": [
        {
          "addressClass": "Full",
          "firstIndex": 0,
          "maxCount": 254,
          "displayFormat": "{0:X2}"
        },
        {
          "addressClass": "Light",
          "firstIndex": 0,
          "maxCount": 4096,
          "displayFormat": "FE:{0:X3}"
        }
      ],
      "persistenceStrategy": "singleFile",
      "pluginsFilePath": "{LocalApplicationData}\\Skyrim Special Edition GOG\\plugins.txt",
      "loadOrderFilePath": "{LocalApplicationData}\\Skyrim Special Edition GOG\\plugins.txt",
      "activeMarker": "*",
      "appDataGameFolderName": "Skyrim Special Edition GOG",
      "useTimestampOrder": false,
      "ignoreOfficialPlugins": true,
      "forcedReadOnly": false,
      "singleFileManagement": true,
      "officialPluginsAreImplicitlyActive": true
    }
  },
  "launcher": {
    "defaultExecutable": "SkyrimSE.exe",
    "plainCommandName": "PlainLaunch",
    "plainCommandText": "Launch Skyrim Special Edition GOG",
    "customCommandName": "CustomLaunch",
    "customCommandText": "Launch Custom Skyrim Special Edition GOG",
    "defaultCommandText": "Launch Skyrim Special Edition GOG",
    "allowCustomCommand": true
  },
  "resources": {
    "iconPath": "SkyrimGOG_logo.ico",
    "categoriesPath": "Categories.xml",
    "baseFilesPath": "skyrimse_base.txt"
  },
  "theme": {
    "primaryColor": "#32689E"
  },
  "setup": {
    "useGenericSetup": true
  },
  "settings": {
    "useGenericSettings": true
  },
  "modInstall": {
    "pathAdjustmentProfile": "none",
    "hardlinkRequiredExtensions": [
      ".esp",
      ".esl",
      ".esm",
      ".bsa",
      ".mp3",
      ".wav",
      ".ogg",
      ".xwm"
    ],
    "realFileRequiredExtensions": [
      ".dll",
      ".exe"
    ],
    "supportsGameRootInstall": true
  },
  "gamebryo": {
    "scriptExtenderExecutables": [
      "skse64_loader.exe"
    ],
    "requiresOptionalFilesCheckOnProfileSwitch": true,
    "optionalFileNamePrefixes": [
      "Bashed Patch",
      "PatchusMaximus",
      "Dual Sheath Redux Patch"
    ],
    "postProfileSwitchToolPath": "{GamePath}\\Data\\tools\\GenerateFNIS_for_Users\\GenerateFNISforUsers.exe",
    "postProfileSwitchToolMessage": "It seems that FNIS is installed: switching mod profiles while using FNIS could require you to run it to prevent broken ingame animations, do you want to run it?",
    "userGameDataPath": "{PersonalData}\\My Games\\Skyrim Special Edition GOG",
    "iniFilePath": "{UserGameData}\\Skyrim.ini",
    "rendererFilePath": "{UserGameData}\\RendererInfo.txt",
    "pluginsFilePath": "{LocalApplicationData}\\Skyrim Special Edition GOG\\plugins.txt",
    "additionalSettingsFiles": {
      "FOPrefsIniPath": "{UserGameData}\\SkyrimPrefs.ini"
    }
  },
  "compatibilityNotes": [
    "This is a separate secondary Game Mode for the GOG Skyrim installation, allowing it to coexist with the Steam SkyrimSE Game Mode and use independent NMM profiles, staging, tool settings and plugin state.",
    "The GOG release uses the Skyrim Special Edition executable and data layout but belongs to the 1.6/Anniversary Edition runtime line.",
    "The GOG installation uses separate Documents and Local AppData directories ending in 'Skyrim Special Edition GOG'.",
    "Use the GOG Anniversary Edition build of SKSE64 that matches the installed SkyrimSE.exe runtime."
  ]
}
