    ],
    "userGameDataPath": "{PersonalData}\\My Games\\Fallout4",
    "iniFilePath": "{UserGameData}\\Fallout4Custom.ini",
    "pluginsFilePath": "{LocalApplicationData}\\Fallout4\\plugins.txt",
    "additionalSettingsFiles": {
      "FOPrefsIniPath": "{UserGameData}\\Fallout4Prefs.ini"
    }
